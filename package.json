{
  "name": "robo-silicon-operations-reporting",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env NODE_DEBUG= WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env NODE_DEBUG= WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "cross-env NODE_DEBUG= WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "railway:build": "prisma generate && npm run build",
    "railway:start": "prisma migrate deploy && npm run start",
    "test": "npm run build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "sample:extract": "tsx scripts/extract-sample.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "chart.js": "^4.5.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "pptxgenjs": "^4.0.1",
    "prisma": "^6.19.0",
    "react": "19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.6",
    "read-excel-file": "^9.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
